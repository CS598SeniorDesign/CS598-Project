DJANGO_SECRET_KEY=some-secret-key

DEBUG=False

LOGLEVEL=info

ALLOWED_HOSTS=localhost,127.0.0.1,[::1]

CORS_ALLOWED_ORIGINS=http://localhost:3000

CSRF_TRUSTED_ORIGINS=http://localhost:3000

JWT_SECRET_KEY=another-secret-key

SECURE_SSL_REDIRECT=False

BACKEND_URL=http://localhost:8000

FRONTEND_URL=http://localhost:3000

REDIS_PASSWORD=your-redis-password
REDIS_CACHE_URL=redis://default:${REDIS_PASSWORD}@redis:6379/0
REDIS_SESSION_URL=redis://default:${REDIS_PASSWORD}@redis:6379/1
REDIS_CELERY_URL=redis://default:${REDIS_PASSWORD}@redis:6379/2

DATABASE_NAME=questlog_db
DATABASE_USERNAME=django
DATABASE_PASSWORD=your-django-password
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_HOST=db
DATABASE_PORT=5432

